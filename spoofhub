-- SMOOTH TELEPORT
----------------------------------------------------------------
local function smoothTeleport(targetPos)
    local char = LP.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum  = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end

    -- Show teleport overlay — removed, death screen now shows on Died event instead

    task.spawn(function()
        local origCollide = {}
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then
                origCollide[p] = p.CanCollide
                p.CanCollide = false
            end
        end
        local targetCF = CFrame.new(targetPos)
        local prevState = hum:GetState()
        hum:ChangeState(Enum.HumanoidStateType.Physics)
        local endTime = tick() + 2.0
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if not root.Parent then conn:Disconnect(); return end
            root.CFrame = targetCF
            root.AssemblyLinearVelocity  = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
            if tick() >= endTime then conn:Disconnect() end
        end)
        task.wait(2.1)
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        for p, v in pairs(origCollide) do
            if p and p.Parent then p.CanCollide = v end
        end
    end)
end

