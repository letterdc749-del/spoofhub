    if S.ESP.Tags[player] then S.ESP.Tags[player]:Destroy(); S.ESP.Tags[player]=nil end
    if S.ESP.Highlights[player] then S.ESP.Highlights[player]:Destroy(); S.ESP.Highlights[player]=nil end
end
local function buildESP(player)
    if player==LP then return end; removeESP(player)
    local char=player.Character; if not char then return end
    local head=char:FindFirstChild("Head"); local hum=char:FindFirstChildOfClass("Humanoid")
    if not head or not hum then return end
    local hl=Instance.new("Highlight"); hl.FillColor=ACC; hl.OutlineColor=ACC
    hl.FillTransparency=0.72; hl.OutlineTransparency=0.1; hl.Adornee=char; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent=char; S.ESP.Highlights[player]=hl
    local bb=Instance.new("BillboardGui"); bb.Name="C3ESP"; bb.Size=UDim2.new(0,88,0,28)
    bb.StudsOffset=Vector3.new(0,2.8,0); bb.AlwaysOnTop=true; bb.MaxDistance=500; bb.Adornee=head; bb.Parent=head; S.ESP.Tags[player]=bb
    local nt=Instance.new("TextLabel",bb); nt.Text=player.Name; nt.Font=Enum.Font.GothamBold; nt.TextSize=10; nt.TextColor3=WHT; nt.BackgroundTransparency=1; nt.Size=UDim2.new(1,0,0,14); nt.TextXAlignment=Enum.TextXAlignment.Center; nt.TextStrokeTransparency=0.3
    local hpBG=Instance.new("Frame",bb); hpBG.Size=UDim2.new(1,0,0,4); hpBG.Position=UDim2.new(0,0,0,15); hpBG.BackgroundColor3=Color3.fromRGB(20,5,5); hpBG.BorderSizePixel=0; Instance.new("UICorner",hpBG).CornerRadius=UDim.new(1,0)
    local hpFill=Instance.new("Frame",hpBG); hpFill.Size=UDim2.new(1,0,1,0); hpFill.BackgroundColor3=GRN; hpFill.BorderSizePixel=0; Instance.new("UICorner",hpFill).CornerRadius=UDim.new(1,0)
    local c2=RunService.Heartbeat:Connect(function()
        if not bb.Parent or not hum.Parent then removeESP(player); return end
        local pct=math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1)
        hpFill.Size=UDim2.new(pct,0,1,0); hpFill.BackgroundColor3=pct>0.5 and GRN or ACC
    end)
    S.ESP.HPConns[player]=c2
end
for _,p in ipairs(Players:GetPlayers()) do
    if p~=LP then p.CharacterAdded:Connect(function() task.wait(0.5); if S.ESP.Enabled then buildESP(p) end end) end
end
Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(function() task.wait(0.5); if S.ESP.Enabled then buildESP(p) end end) end)
Players.PlayerRemoving:Connect(removeESP)

-- ── AIMLOCK ─────────────────────────────────────────────────
local function getAimTarget()
    local center=Vector2.new(Cam.ViewportSize.X/2,Cam.ViewportSize.Y/2); local best,bestDist=nil,math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        local char=p.Character; if not char then continue end
        local root=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health<=0 then continue end
        local sp,vis=Cam:WorldToScreenPoint(root.Position); if not vis then continue end
        local d=(Vector2.new(sp.X,sp.Y)-center).Magnitude; if d>S.Aimlock.FOV then continue end
        if d<bestDist then best,bestDist=p,d end
    end
    return best
end

