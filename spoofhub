                mimicStatusLbl.Text="Not mimicking anyone"; mimicStatusLbl.TextColor3=T.mute
                notify("Mimic","Stopped",nil)
            else
                S.Mimic.Target=player; S.Mimic.Enabled=true
                mimicStatusLbl.Text="Mimicking: "..player.DisplayName; mimicStatusLbl.TextColor3=T.green
                if S.Mimic.Conn then S.Mimic.Conn:Disconnect(); S.Mimic.Conn=nil end
                S.Mimic.Conn=RunService.Heartbeat:Connect(function()
                    if not S.Mimic.Enabled or not S.Mimic.Target then return end
                    local tchar=S.Mimic.Target.Character
                    local troot=tchar and tchar:FindFirstChild("HumanoidRootPart")
                    local thum=tchar and tchar:FindFirstChildOfClass("Humanoid")
                    local char=LP.Character
                    local root=char and char:FindFirstChild("HumanoidRootPart")
                    local hum=char and char:FindFirstChildOfClass("Humanoid")
                    if not troot or not root or not hum or not thum then return end
                    -- Copy position offset (mirrored — face opposite direction)
                    local mirroredCF=CFrame.new(troot.Position)*CFrame.Angles(0,troot.CFrame.LookVector.X*math.pi,0)
                    root.CFrame=root.CFrame:Lerp(mirroredCF,0.2)
                    root.AssemblyLinearVelocity=troot.AssemblyLinearVelocity
                    -- Copy walk speed
                    hum.WalkSpeed=thum.WalkSpeed
                    -- Copy jump
                    if thum.Jump then hum.Jump=true end
                end)
                notify("Mimic","Now mimicking "..player.DisplayName,"success")
            end
            refreshMimicList()
        end)
        btn.MouseEnter:Connect(function() if S.Mimic.Target~=player then TweenService:Create(btn,TweenInfo.new(0.1),{BackgroundColor3=T.raised}):Play() end end)
        btn.MouseLeave:Connect(function() TweenService:Create(btn,TweenInfo.new(0.1),{BackgroundColor3=T.card}):Play() end)
    end
end
