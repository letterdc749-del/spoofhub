                S.ActiveSlider = {
                    track=track, fill=fill2, dot=dot2,
                    min=0, max=maxV,
                    setV=function(v) onCh(math.floor(v)); rebuild() end,
                    cb=nil
                }
            end
        end)
    end
    makeRGBSlider("R", 28, r, 255, function(v) r=v end)
    makeRGBSlider("G", 50, g, 255, function(v) g=v end)
