local function Toggle(parent,label,sublabel,cb,defaultOn)
    local row=Instance.new("Frame",parent)
    row.Size=UDim2.new(1,0,0,26); row.BackgroundColor3=CARD; row.BorderSizePixel=0
    local lbl=Instance.new("TextLabel",row); lbl.Text=label:lower(); lbl.Font=Enum.Font.Code; lbl.TextSize=11; lbl.TextColor3=TXT
    lbl.BackgroundTransparency=1; lbl.Size=UDim2.new(1,-60,1,0); lbl.Position=UDim2.new(0,8,0,0); lbl.TextXAlignment=Enum.TextXAlignment.Left
    local hb=Instance.new("TextButton",row); hb.Size=UDim2.new(0,50,0,20); hb.Position=UDim2.new(1,-54,0.5,-10)
    hb.Font=Enum.Font.Code; hb.TextSize=10; hb.BorderSizePixel=0; hb.AutoButtonColor=false
    local on=defaultOn or false
    local function refresh(v)
        hb.Text=v and "[ on ]" or "[ off ]"
        hb.TextColor3=v and GRN or SUB
        hb.BackgroundColor3=v and CARDON or CARD
        row.BackgroundColor3=v and CARDON or CARD
    end
    refresh(on)
    hb.MouseButton1Click:Connect(function()
        on=not on; refresh(on); if cb then cb(on) end
    end)
    return row, function(v) on=v; refresh(v); if cb then cb(v) end end
end

