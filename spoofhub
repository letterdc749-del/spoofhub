-- ── SMOOTH TELEPORT (from Spoof Hub) ────────────────────────
local function smoothTeleport(targetPos)
    local char=LP.Character; if not char then return end
    local root=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end
    task.spawn(function()
        local origCollide={}
        for _,p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then origCollide[p]=p.CanCollide; p.CanCollide=false end
        end
        hum:ChangeState(Enum.HumanoidStateType.Physics)
        local endTime=tick()+2.0; local c
        c=RunService.Heartbeat:Connect(function()
            if not root.Parent then c:Disconnect(); return end
            root.CFrame=CFrame.new(targetPos); root.AssemblyLinearVelocity=Vector3.zero; root.AssemblyAngularVelocity=Vector3.zero
            if tick()>=endTime then c:Disconnect() end
        end)
        task.wait(2.1)
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        for p,v in pairs(origCollide) do if p and p.Parent then p.CanCollide=v end end
    end)
end

-- ── SLOW TRAVEL (from Spoof Hub) ────────────────────────────
local SlowTravel={Active=false,Target=nil,Name="",Speed=20,Conn=nil}
local function stopSlowTravel()
    if SlowTravel.Conn then SlowTravel.Conn:Disconnect(); SlowTravel.Conn=nil end
    SlowTravel.Active=false; SlowTravel.Target=nil; SlowTravel.Name=""
end

local function startSlowTravel(targetPos,locName)
    stopSlowTravel(); SlowTravel.Active=true; SlowTravel.Target=targetPos; SlowTravel.Name=locName
    local UY=-3
    local function disCol() local c=LP.Character; if not c then return end; local root=c:FindFirstChild("HumanoidRootPart"); if root then root.CanCollide=false end end
    local phase=1
    SlowTravel.Conn=RunService.Heartbeat:Connect(function(dt)
        if not SlowTravel.Active then return end
        local char=LP.Character; local root=char and char:FindFirstChild("HumanoidRootPart")
        if not root then stopSlowTravel(); return end
        disCol(); root.AssemblyLinearVelocity=Vector3.zero; root.AssemblyAngularVelocity=Vector3.zero
        local pos=root.Position
        if phase==1 then
            if math.abs(pos.Y-UY)<5 then root.CFrame=CFrame.new(Vector3.new(pos.X,UY,pos.Z)); phase=2; return end
            root.CFrame=CFrame.new(pos+Vector3.new(0,-math.min(SlowTravel.Speed*dt,math.abs(pos.Y-UY)),0))
        elseif phase==2 then
            local under=Vector3.new(targetPos.X,UY,targetPos.Z); local diff=under-pos; local hd=Vector3.new(diff.X,0,diff.Z).Magnitude
            if hd<5 then root.CFrame=CFrame.new(under); phase=3; return end
            root.CFrame=CFrame.new(pos+Vector3.new(diff.X,0,diff.Z).Unit*math.min(SlowTravel.Speed*dt,hd))
        elseif phase==3 then
            local diff=targetPos-pos
            if diff.Magnitude<4 then root.CFrame=CFrame.new(targetPos); local n=SlowTravel.Name; stopSlowTravel(); notify("Arrived","✓ "..n,"success"); return end
            root.CFrame=CFrame.new(pos+Vector3.new(0,math.min(SlowTravel.Speed*dt,math.abs(diff.Y)),0))
        end
    end)
end

