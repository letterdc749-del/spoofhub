-- Drag support
local mbDragging = false
local mbDragOff = Vector2.new()

MenuBtn.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        mbDragging = true
        mbDragOff = Vector2.new(
            inp.Position.X - MenuBtn.AbsolutePosition.X,
            inp.Position.Y - MenuBtn.AbsolutePosition.Y
        )
    end
end)

MenuBtn.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        mbDragging = false
    end
end)

RunService.RenderStepped:Connect(function()
    if not mbDragging then return end
    local mp
    if IS_MOBILE then
        local t = UserInputService:GetTouchPositions()
        mp = #t > 0 and t[1] or UserInputService:GetMouseLocation()
    else
        mp = UserInputService:GetMouseLocation()
    end
    MenuBtn.Position = UDim2.new(
        0, math.clamp(mp.X - mbDragOff.X, 0, workspace.CurrentCamera.ViewportSize.X - 48),
        0, math.clamp(mp.Y - mbDragOff.Y, 0, workspace.CurrentCamera.ViewportSize.Y - 48)
    )
end)

-- Click to toggle (only if not dragged)
local mbClickPos = Vector2.new()
MenuBtn.MouseButton1Down:Connect(function()
    mbClickPos = UserInputService:GetMouseLocation()
end)
MenuBtn.MouseButton1Up:Connect(function()
    local cur = UserInputService:GetMouseLocation()
    if (cur - mbClickPos).Magnitude < 6 then
        S.GUI.Visible = not S.GUI.Visible
        if S.GUI.Visible then
            Main.Visible = true
            TweenService:Create(Main, TweenInfo.new(0.2, Enum.EasingStyle.Quart), {BackgroundTransparency=0}):Play()
        else
            TweenService:Create(Main, TweenInfo.new(0.2, Enum.EasingStyle.Quart), {BackgroundTransparency=1}):Play()
            task.wait(0.21); Main.Visible = false; Main.BackgroundTransparency = 0
        end
    end
end)

-- Pulse border when menu is open
RunService.RenderStepped:Connect(function(dt)
    if S.GUI.Visible then
        mbStroke.Color = T.accent
        TweenService:Create(mbLabel, TweenInfo.new(0.15), {TextColor3=T.white}):Play()
    else
        mbStroke.Color = T.accentD
        TweenService:Create(mbLabel, TweenInfo.new(0.15), {TextColor3=T.accent}):Play()
    end
end)
