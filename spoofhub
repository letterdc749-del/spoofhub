-- HOTKEY OVERLAY  (bottom left)
----------------------------------------------------------------
local HotkeyFrame=Instance.new("Frame",SG)
HotkeyFrame.Name="HotkeyOverlay"; HotkeyFrame.Size=UDim2.new(0,200,0,0)
HotkeyFrame.Position=UDim2.new(0,10,1,-200); HotkeyFrame.AnchorPoint=Vector2.new(0,1)
HotkeyFrame.BackgroundTransparency=1; HotkeyFrame.AutomaticSize=Enum.AutomaticSize.Y; HotkeyFrame.ZIndex=10

local HKLayout=Instance.new("UIListLayout",HotkeyFrame)
HKLayout.SortOrder=Enum.SortOrder.LayoutOrder; HKLayout.VerticalAlignment=Enum.VerticalAlignment.Bottom; HKLayout.Padding=UDim.new(0,3)

local function keyName(kc) return tostring(kc):gsub("Enum.KeyCode.","") end

local BLUE = Color3.fromRGB(50, 150, 255)
local BLUE_DIM = Color3.fromRGB(10, 40, 80)

local HOTKEYS = {
    { label="Toggle Menu", getKey=function() return keyName(S.GUI.ToggleKey) end, isActive=function() return S.GUI.Visible end },
    { label="Aimlock",     getKey=function() return "Hold Q" end,                 isActive=function() return S.Aimlock.Enabled end },
    { label="Noclip",      getKey=function() return "V" end,                      isActive=function() return S.Noclip.Enabled end },
    { label="Fly",         getKey=function() return "F" end,                      isActive=function() return S.Fly.Enabled end },
    { label="Freecam",     getKey=function() return "C" end,                      isActive=function() return S.FreeCam.Enabled end },
}

local hkRows={}
for i,hk in ipairs(HOTKEYS) do
    local row=Instance.new("Frame",HotkeyFrame)
    row.Size=UDim2.new(1,0,0,18); row.BackgroundTransparency=1; row.LayoutOrder=i; row.ZIndex=10
    local keyBadge=Instance.new("TextLabel",row)
    keyBadge.Font=Enum.Font.GothamBold; keyBadge.TextSize=10; keyBadge.Text=hk.getKey()
    keyBadge.TextColor3=T.accent; keyBadge.BackgroundColor3=Color3.fromRGB(20,10,12)
    keyBadge.Size=UDim2.new(0,70,1,0); keyBadge.TextXAlignment=Enum.TextXAlignment.Center
    keyBadge.BackgroundTransparency=0.3; keyBadge.BorderSizePixel=0; keyBadge.ZIndex=10
    Instance.new("UICorner",keyBadge).CornerRadius=UDim.new(0,4)
    local badgeStroke=Instance.new("UIStroke",keyBadge); badgeStroke.Color=T.accentD
    keyBadge.TextStrokeTransparency=0.5; keyBadge.TextStrokeColor3=T.black
    local lbl=Instance.new("TextLabel",row)
    lbl.Font=Enum.Font.Gotham; lbl.TextSize=10; lbl.Text=hk.label
    lbl.TextColor3=T.sub; lbl.BackgroundTransparency=1
    lbl.Size=UDim2.new(1,-78,1,0); lbl.Position=UDim2.new(0,76,0,0)
    lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.TextStrokeTransparency=0.5; lbl.TextStrokeColor3=T.black; lbl.ZIndex=10
    table.insert(hkRows,{badge=keyBadge,stroke=badgeStroke,lbl=lbl,hk=hk})
end

task.spawn(function()
    while SG.Parent do
        for _,r in ipairs(hkRows) do
            r.badge.Text=r.hk.getKey()
            local active = r.hk.isActive and r.hk.isActive()
            if active then
                TweenService:Create(r.badge,TweenInfo.new(0.15),{
                    TextColor3=BLUE,
                    BackgroundColor3=Color3.fromRGB(5,20,50),
                }):Play()
                r.stroke.Color=BLUE
                TweenService:Create(r.lbl,TweenInfo.new(0.15),{TextColor3=BLUE}):Play()
            else
                TweenService:Create(r.badge,TweenInfo.new(0.15),{
                    TextColor3=T.accent,
                    BackgroundColor3=Color3.fromRGB(20,10,12),
                }):Play()
                r.stroke.Color=T.accentD
                TweenService:Create(r.lbl,TweenInfo.new(0.15),{TextColor3=T.sub}):Play()
            end
        end
        task.wait(0.1)
    end
end)

