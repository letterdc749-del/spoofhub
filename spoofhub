task.spawn(function()
    while SG.Parent do
        local now=tick()
        lFStatus.Text="Status: "..farmStats.status
        if farmStats.stepEnd then
            local rem=math.max(0,farmStats.stepEnd-now)
            local pct=math.floor((1-rem/math.max(farmStats.stepTotal,1))*100)
            lFTimer.Text=string.format("⏱ %.1fs left [%d%%]",rem,pct)
            lFTimer.TextColor3=rem<5 and ACC or YEL
        else lFTimer.Text="⏱ --"; lFTimer.TextColor3=YEL end
        if farmStats.cookStart then
            local e=math.floor(now-farmStats.cookStart)
            lFCook.Text=string.format("🕐 Cook: %d:%02d",math.floor(e/60),e%60)
        else lFCook.Text="🕐 Cook: --" end
        if farmStats.cookCount>0 then
            local avg=math.floor(farmStats.totalCookSecs/farmStats.cookCount)
            lFAvg.Text=string.format("📊 Avg: %d:%02d",math.floor(avg/60),avg%60)
        else lFAvg.Text="📊 Avg: --" end
        local s=math.floor(now-farmStats.sessionStart)
        lFSession.Text=string.format("⏳ Session: %d:%02d",math.floor(s/60),s%60)
        lFBatches.Text="Batches Done: "..farmStats.batches
        lFSmall.Text  ="Small (total): "..farmStats.small
        lFMedium.Text ="Medium (total): "..farmStats.medium
        lFLarge.Text  ="Large (total): "..farmStats.large
        lFInBag.Text  ="In bag now: "..countMarshmallowInv()
        lFLast.Text   ="Last bag: "..(farmStats.lastBatch~="" and farmStats.lastBatch or "--")
        if #farmStats.batchLog>0 then lFLog.Text="Last 5: "..table.concat(farmStats.batchLog," · ") end
        lFWater.Text  ="Water: "..countInv("Water")
        lFSugar.Text  ="Sugar Block Bag: "..countInv("Sugar Block Bag")
        lFGelatin.Text="Gelatin: "..countInv("Gelatin")
        lFFailed.Text ="Failed: "..farmStats.failed
        task.wait(0.2)
    end
end)

