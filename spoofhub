    farmStats.stepEnd=tick()+secs; farmStats.stepTotal=secs
    local t=0
    while farmEnabled and t<secs do task.wait(0.2); t+=0.2 end
    farmStats.stepEnd=nil; farmStats.stepTotal=0
end

local function pressE()
    VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.1)
    VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function playErrorSound()
    pcall(function()
        local s=Instance.new("Sound",workspace); s.SoundId="rbxassetid://131961136"
        s.Volume=0.5; s.RollOffMaxDistance=0; s:Play()
        game:GetService("Debris"):AddItem(s,3)
    end)
end

local function buyByText(searchText)
    for _=1,30 do
        for _,v in ipairs(LP.PlayerGui:GetDescendants()) do
            if v:IsA("TextButton") and v.Visible then
                if v.Text:upper():find(searchText:upper(),1,true) then
                    pcall(function() v.MouseButton1Click:Fire() end)
                    pcall(function()
                        local pos=v.AbsolutePosition+v.AbsoluteSize*0.5
                        VIM:SendMouseButtonEvent(pos.X,pos.Y,0,true,game,1)
                        task.wait(0.05)
                        VIM:SendMouseButtonEvent(pos.X,pos.Y,0,false,game,1)
                    end)
                    unequipAll(); return true
                end
            end
        end
        task.wait(0.1)
    end
    return false
end

local function doCook()
    farmStats.cookStart=tick()
    local function fail(msg)
        playErrorSound(); farmStats.status=msg; farmStats.failed+=1; farmStats.cookStart=nil; return false
    end

    farmStats.status="Equipping Water..."
    if not equipWithRetry("Water") then return fail("❌ No Water!") end
    task.wait(0.05); pressE()
    farmStats.status="⏳ Water (22s)"; waitI(22)
    if not farmEnabled then farmStats.cookStart=nil; return false end

    farmStats.status="Equipping Sugar Block Bag..."
    if equipWithRetry("Sugar Block Bag") then
        task.wait(0.05); pressE()
        farmStats.status="⏳ Sugar (2.5s)"; waitI(2.5)
        if not farmEnabled then farmStats.cookStart=nil; return false end
    end

    farmStats.status="Equipping Gelatin..."
    if equipWithRetry("Gelatin") then
        task.wait(0.05); pressE()
        farmStats.status="⏳ Cooking (47s)"; waitI(47)
        if not farmEnabled then farmStats.cookStart=nil; return false end
    end

    farmStats.status="Waiting for Empty Bag..."
    local w=0
    while w<6 and farmEnabled do
        if LP.Backpack:FindFirstChild("Empty Bag") or (LP.Character and LP.Character:FindFirstChild("Empty Bag")) then break end
        task.wait(0.5); w+=0.5
    end
    if not farmEnabled then farmStats.cookStart=nil; return false end

    farmStats.status="Collecting marshmallow..."
    local function countWord(word)
        local n=0
        local function scan(c) if not c then return end
            for _,v in ipairs(c:GetChildren()) do if v:IsA("Tool") and v.Name:lower():find(word) then n+=1 end end
        end
        scan(LP.Backpack); if LP.Character then scan(LP.Character) end; return n
    end
    local preSm=countWord("small"); local preMd=countWord("medium"); local preLg=countWord("large")

    if equipWithRetry("Empty Bag") then
        task.wait(0.05); pressE(); task.wait(2)
    end

    local diffLg=countWord("large")-preLg; local diffMd=countWord("medium")-preMd; local diffSm=countWord("small")-preSm
    local gotSize=nil
    if diffLg>0 then gotSize="Large" elseif diffMd>0 then gotSize="Medium" elseif diffSm>0 then gotSize="Small" end

    if not gotSize then
        local function scanAny(c) if not c then return end
            for _,v in ipairs(c:GetChildren()) do
                if v:IsA("Tool") then local n=v.Name:lower()
                    if n:find("marshmallow") or n:find("marsh") then
                        if n:find("large") then gotSize="Large"
                        elseif n:find("medium") then gotSize="Medium"
                        elseif n:find("small") then gotSize="Small" end
                        farmStats.lastBatch=v.Name; return
                    end
                end
            end
        end
        scanAny(LP.Backpack); if not gotSize and LP.Character then scanAny(LP.Character) end
    end

    if gotSize then
        if gotSize=="Large" then farmStats.large+=1
        elseif gotSize=="Medium" then farmStats.medium+=1
        else farmStats.small+=1 end
        logBatch(gotSize); farmStats.status="✅ Got "..gotSize.." MS!"
    else
        farmStats.status="⚠ Collected (unknown)"; farmStats.small+=1; logBatch("?")
    end

    farmStats.batches+=1
    if farmStats.cookStart then farmStats.totalCookSecs+=tick()-farmStats.cookStart; farmStats.cookCount+=1 end
    farmStats.cookStart=nil
    return true
end

local function doSell()
    local ms=getMarshmallows()
    if #ms==0 then farmStats.status="Nothing to sell"; return end
    smoothTeleport(SELLER_POS); task.wait(1)
    local sold=0; ms=getMarshmallows()
    while #ms>0 and farmEnabled do
        local item=ms[1]
        if item.Parent~=LP.Character then
            local hum=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
            if hum then pcall(function() hum:EquipTool(item) end); task.wait(0.3) end
        end
        if item.Parent==LP.Character then
            pressE(); task.wait(1); sold+=1
        else
            pcall(function() item.Parent=LP.Character end); task.wait(0.3); pressE(); task.wait(1); sold+=1
        end
        ms=getMarshmallows()
    end
    farmStats.status="Sold "..sold.." MS"; unequipAll()
end

local function doBuy()
    smoothTeleport(SELLER_POS); task.wait(0.8)
    farmStats.status="Buying supplies..."
    if countInv("Water")==0 then buyByText("WATER"); task.wait(0.5) end
    if countInv("Sugar Block Bag")==0 then buyByText("SUGAR BLOCK BAG"); task.wait(0.5) end
    if countInv("Gelatin")==0 then buyByText("GELATIN"); task.wait(0.5) end
    unequipAll(); farmStats.status="Supplies bought"
end

local farmWatch=nil
local function stopFarm()
    farmEnabled=false
    if S.Farm.Thread then task.cancel(S.Farm.Thread); S.Farm.Thread=nil end
    if farmWatch then task.cancel(farmWatch); farmWatch=nil end
    farmStats.cookStart=nil; farmStats.stepEnd=nil; farmStats.status="Idle"
end

local lastStatusTime=tick(); local lastFarmStatus=""
local function startWatchdog()
    if farmWatch then task.cancel(farmWatch); farmWatch=nil end
    farmWatch=task.spawn(function()
        while farmEnabled do
            task.wait(5)
            if farmStats.status~=lastFarmStatus then lastFarmStatus=farmStats.status; lastStatusTime=tick() end
            if farmEnabled and tick()-lastStatusTime>90 then
                playErrorSound(); farmStats.status="🔄 Watchdog restart!"
                if S.Farm.Thread then task.cancel(S.Farm.Thread); S.Farm.Thread=nil end
                farmStats.cookStart=nil; farmStats.stepEnd=nil; lastStatusTime=tick()
                S.Farm.Thread=task.spawn(function()
                    while farmEnabled do
                        local ok=doCook()
                        if not ok and farmEnabled then task.wait(2) end
                        if S.Farm.Looping and farmEnabled then doSell(); doBuy() end
                        task.wait(0.3)
                    end
                    farmStats.status="Idle"
                end)
            end
        end
    end)
end

local function startFarm()
    stopFarm(); farmEnabled=true; S.Farm.Looping=false
    startWatchdog()
    S.Farm.Thread=task.spawn(function()
        while farmEnabled do
            local ok=doCook()
            if not ok and farmEnabled then task.wait(2) end
            task.wait(0.3)
        end
        farmStats.status="Idle"
    end)
end

local function startLoop()
    stopFarm(); farmEnabled=true; S.Farm.Looping=true
    if countInv("Water")==0 or countInv("Sugar Block Bag")==0 or countInv("Gelatin")==0 then doBuy() end
    startWatchdog()
    S.Farm.Thread=task.spawn(function()
        while farmEnabled do
            local ok=doCook()
            if not farmEnabled then break end
            if not ok then task.wait(2); doBuy(); continue end
            doSell(); if not farmEnabled then break end
            doBuy(); task.wait(0.5)
        end
        farmStats.status="Idle"
    end)
end

