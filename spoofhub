end

local function equipItem(name)
    local c=LP.Character; if not c then return false end
    if c:FindFirstChild(name) then return true end
    local tool=LP.Backpack:FindFirstChild(name); if not tool then return false end
    local hum=c:FindFirstChildOfClass("Humanoid"); if not hum then return false end
    pcall(function() hum:EquipTool(tool) end); task.wait(0.2)
    return c:FindFirstChild(name)~=nil
end

