local function OptionPair(parent, optA, optB, current, cb)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1,0,0,36); row.BackgroundTransparency = 1
    local function makeOpt(label, x, isActive)
        local b = Instance.new("TextButton", row)
        b.Text = label; b.Font = Enum.Font.Gotham; b.TextSize = 12
        b.Size = UDim2.new(0.5,-4,1,0); b.Position = UDim2.new(x,x==0 and 0 or 8,0,0)
        b.BorderSizePixel = 0; b.AutoButtonColor = false
        b.BackgroundColor3 = isActive and T.accent or T.card
        b.TextColor3 = isActive and T.white or T.mute
        Instance.new("UICorner", b).CornerRadius = UDim.new(0,6)
        return b
    end
    local bA = makeOpt(optA, 0,   current == optA)
    local bB = makeOpt(optB, 0.5, current == optB)
    local function pick(v)
        TweenService:Create(bA,TweenInfo.new(0.1),{BackgroundColor3=v==optA and T.accent or T.card, TextColor3=v==optA and T.white or T.mute}):Play()
        TweenService:Create(bB,TweenInfo.new(0.1),{BackgroundColor3=v==optB and T.accent or T.card, TextColor3=v==optB and T.white or T.mute}):Play()
        if cb then cb(v) end
    end
    bA.MouseButton1Click:Connect(function() pick(optA) end)
    bB.MouseButton1Click:Connect(function() pick(optB) end)
    return row
end

