    lbl.TextColor3 = T.text; lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1,-70,0,18); lbl.Position = UDim2.new(0,0,0,8)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    if sublabel then
        local sub = Instance.new("TextLabel", row)
        sub.Text = sublabel; sub.Font = Enum.Font.Gotham; sub.TextSize = 10
        sub.TextColor3 = T.mute; sub.BackgroundTransparency = 1
        sub.Size = UDim2.new(1,-70,0,14); sub.Position = UDim2.new(0,0,0,27)
        sub.TextXAlignment = Enum.TextXAlignment.Left
    end
    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(0,42,0,22); track.Position = UDim2.new(1,-42,0.5,-11)
    track.BackgroundColor3 = T.raised; track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0,16,0,16); knob.Position = UDim2.new(0,3,0.5,-8)
    knob.BackgroundColor3 = T.mute; knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
    local hitbox = Instance.new("TextButton", track)
    hitbox.Text=""; hitbox.BackgroundTransparency=1; hitbox.Size=UDim2.new(1,0,1,0)
    local on = stateTab ~= nil and S[stateTab][stateKey] or false
    local function refresh(v)
        TweenService:Create(knob, TweenInfo.new(0.18, Enum.EasingStyle.Quart), {
            Position         = v and UDim2.new(0,23,0.5,-8) or UDim2.new(0,3,0.5,-8),
            BackgroundColor3 = v and T.white or T.mute,
        }):Play()
        TweenService:Create(track, TweenInfo.new(0.18, Enum.EasingStyle.Quart), {
            BackgroundColor3 = v and T.accent or T.raised,
        }):Play()
        TweenService:Create(row, TweenInfo.new(0.18), {
            BackgroundColor3 = v and Color3.fromRGB(28,16,18) or T.card,
        }):Play()
    end
    refresh(on)
    hitbox.MouseButton1Click:Connect(function()
        on = not on
        if stateTab then S[stateTab][stateKey] = on end
        refresh(on)
        if cb then cb(on) end
        notify(label, on and "Enabled" or "Disabled", on and "success" or nil)
    end)
    return row
end

