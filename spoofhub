    stopAll(); Rec.Frames={}; Rec.Recording=true
    rBtn.Text="⏹  Stop"; rBtn.BackgroundColor3=T.accent; rStroke.Color=T.accentG
    TweenService:Create(pBtn,TweenInfo.new(0.1),{TextColor3=T.mute,BackgroundColor3=T.card}):Play(); pStroke.Color=T.border
    notify("Recorder","Recording! Do your inputs",nil)
    Rec.Conn=RunService.RenderStepped:Connect(function()
        if not Rec.Recording then return end
        local held={}
        for _,kc in ipairs(WATCH_KEYS) do held[kc]=UserInputService:IsKeyDown(kc) end
        held["MB1"]=UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
        held["MB2"]=UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
        local mp=UserInputService:GetMouseLocation(); held["MX"]=mp.X; held["MY"]=mp.Y
        table.insert(Rec.Frames,held); upd()
