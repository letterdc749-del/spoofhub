-- Hooks the internal remote that drains stamina and blocks it
----------------------------------------------------------------
task.spawn(function()
    -- Scan all RemoteEvents and RemoteFunctions for stamina-related ones
    -- then block them from firing when InfiniteStamina is on
    local function hookRemote(remote)
        local name = remote.Name:lower()
        if name:find("stam") or name:find("sprint") or name:find("energy") or name:find("drain") or name:find("tire") then
            local mt = getrawmetatable(game)
            local oldNamecall = mt.__namecall
            local blocked = false
            setreadonly(mt, false)
            mt.__namecall = function(self, ...)
                local method = getnamecallmethod()
                if S.InfiniteStamina.Enabled and self == remote and
                   (method == "FireServer" or method == "InvokeServer") then
                    return
                end
                return oldNamecall(self, ...)
            end
            setreadonly(mt, true)
        end
    end

    -- Hook existing remotes
    for _,v in ipairs(game:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            pcall(hookRemote, v)
        end
    end
    -- Hook new remotes as they appear
    game.DescendantAdded:Connect(function(v)
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            pcall(hookRemote, v)
        end
    end)

    -- Also try to find and freeze any local stamina value
    RunService.Heartbeat:Connect(function()
        if not S.InfiniteStamina.Enabled then return end
        local char = LP.Character
        if not char then return end
        for _,v in ipairs(char:GetDescendants()) do
            if (v:IsA("NumberValue") or v:IsA("IntValue")) then
                local n = v.Name:lower()
                if n:find("stam") or n:find("sprint") or n:find("energy") then
                    pcall(function()
                        if v.Value < v.Parent:FindFirstChild("Max"..v.Name) and v.Parent:FindFirstChild("Max"..v.Name) then
                            v.Value = v.Parent:FindFirstChild("Max"..v.Name).Value
                        elseif v.Value < 100 then
                            v.Value = 100
                        end
                    end)
                end
            end
        end
        -- Try common attribute names
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            for _,attr in ipairs({"Stamina","MaxStamina","Sprint","SprintStamina","Energy","Endurance"}) do
                pcall(function()
                    local v = hum:GetAttribute(attr)
                    if type(v)=="number" and v < 95 then
                        hum:SetAttribute(attr, 100)
                    end
                end)
            end
        end
    end)
end)

