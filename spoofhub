local function getAimTarget()
    local center=Vector2.new(Cam.ViewportSize.X/2,Cam.ViewportSize.Y/2)
    local best,bestVal=nil,math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        local char=p.Character; if not char then continue end
        local root=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health<=0 then continue end
        local sp,vis=Cam:WorldToScreenPoint(root.Position); if not vis then continue end
        local d=(Vector2.new(sp.X,sp.Y)-center).Magnitude; if d>S.Aimlock.FOV then continue end
        local val=S.Aimlock.Priority=="Closest" and d or hum.Health
        if val<bestVal then best,bestVal=p,val end
    end
    return best
end

