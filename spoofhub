-- ── MAIN RENDER LOOP ────────────────────────────────────────
local fcCF=CFrame.new(0,10,0); local fcYaw=0; local fcPitch=0
RunService.RenderStepped:Connect(function(dt)
    -- Drag
    if S.GUI.Dragging then
        local mp=UserInputService:GetMouseLocation()
        Main.Position=UDim2.new(0,mp.X-S.GUI.DragOff.X,0,mp.Y-S.GUI.DragOff.Y)
    end

    -- Slider
    if S.ActiveSlider then
        local sl=S.ActiveSlider; local ix=UserInputService:GetMouseLocation().X
        local rel=math.clamp((ix-sl.track.AbsolutePosition.X)/sl.track.AbsoluteSize.X,0,1)
        local v=sl.min+rel*(sl.max-sl.min)
        sl.fill.Size=UDim2.new(rel,0,1,0); sl.dot.Position=UDim2.new(rel,0,0.5,0); sl.setV(v); if sl.cb then sl.cb(v) end
    end

    -- Aimlock
    if S.Aimlock.Enabled and UserInputService:IsKeyDown(Enum.KeyCode.Q) then
        local target=getAimTarget()
        if target then local char=target.Character; if char then local root=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChildOfClass("Humanoid"); if root and hum and hum.Health>0 then Cam.CFrame=Cam.CFrame:Lerp(CFrame.new(Cam.CFrame.Position,root.Position+Vector3.new(0,1.5,0)),S.Aimlock.Smooth) end end end
    end

    -- ESP
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        if S.ESP.Enabled then if not S.ESP.Tags[p] and p.Character then buildESP(p) end
        else if S.ESP.Tags[p] or S.ESP.Highlights[p] then removeESP(p) end end
    end

    -- Noclip
    if S.Noclip.Enabled then
        local char=LP.Character; if char then
            for _,p in ipairs(char:GetDescendants()) do
                if p:IsA("BasePart") and p.Name~="LeftFoot" and p.Name~="RightFoot" then p.CanCollide=false end
            end
        end
    end

    -- Fly
    if S.Fly.Enabled and S.Fly.Body and S.Fly.Gyro then
        local cf=Cam.CFrame; local vel=Vector3.zero; local spd=S.Fly.Speed
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel+=cf.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel-=cf.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel-=cf.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel+=cf.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel+=Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vel-=Vector3.yAxis end
        S.Fly.Body.Velocity=vel.Magnitude>0 and vel.Unit*spd or Vector3.zero; S.Fly.Gyro.CFrame=cf
    end

    -- Freecam
    if S.FreeCam.Enabled then
        local spd=S.FreeCam.Speed*dt; local vel=Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel+=fcCF.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel-=fcCF.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel-=fcCF.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel+=fcCF.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then vel+=Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then vel-=Vector3.yAxis end
        local md=UserInputService:GetMouseDelta(); fcYaw-=md.X*0.3; fcPitch=math.clamp(fcPitch-md.Y*0.3,-89,89)
        local rot=CFrame.Angles(0,math.rad(fcYaw),0)*CFrame.Angles(math.rad(fcPitch),0,0)
        if vel.Magnitude>0 then fcCF=CFrame.new(fcCF.Position+vel.Unit*spd)*rot else fcCF=CFrame.new(fcCF.Position)*rot end
        Cam.CFrame=fcCF
    end
end)

