local Connections = {}
local function connect(sig, fn)
    local c = sig:Connect(fn)
    table.insert(Connections, c)
    return c
end
local function disconnectAll()
    for _, c in ipairs(Connections) do pcall(function() c:Disconnect() end) end
    Connections = {}
end

