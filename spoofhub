local nearT=0
RunService.Heartbeat:Connect(function(dt)
    if not S.NearAlert.Enabled then return end
    nearT+=dt; if nearT<1 then return end; nearT=0
    local char=LP.Character; local root=char and char:FindFirstChild("HumanoidRootPart"); if not root then return end
    local now=tick(); if now-S.NearAlert.LastAlert<5 then return end
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        local tc=p.Character; local tr=tc and tc:FindFirstChild("HumanoidRootPart")
        if tr and (root.Position-tr.Position).Magnitude<=S.NearAlert.Radius then
            S.NearAlert.LastAlert=now; notify("⚠ Player Nearby",p.DisplayName.." is close!",nil); break
        end
    end
end)

