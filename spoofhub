conn(UserInputService.InputBegan,function(inp,gpe)
    if gpe or S.Listening then return end
    if inp.KeyCode==S.GUI.ToggleKey then
        S.GUI.Visible=not S.GUI.Visible; Main.Visible=S.GUI.Visible
    end
    if inp.KeyCode==Enum.KeyCode.V then
        S.Noclip.Enabled=not S.Noclip.Enabled
        if not S.Noclip.Enabled then
            local c=LP.Character; if c then
                for _,p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=true end end
                local hum=c:FindFirstChildOfClass("Humanoid"); if hum then pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end) end
            end
        end
    end
    if inp.KeyCode==Enum.KeyCode.F then
        S.Fly.Enabled=not S.Fly.Enabled
        local char=LP.Character; if not char then return end
        local root=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChildOfClass("Humanoid")
        if not root or not hum then return end
        if S.Fly.Enabled then
            hum.PlatformStand=true
            local bv=Instance.new("BodyVelocity",root); bv.Name="C3FlyVel"; bv.Velocity=Vector3.zero; bv.MaxForce=Vector3.new(1e5,1e5,1e5)
            local bg=Instance.new("BodyGyro",root); bg.Name="C3FlyGyro"; bg.MaxTorque=Vector3.new(1e5,1e5,1e5); bg.P=1e4; bg.CFrame=root.CFrame
            S.Fly.Body=bv; S.Fly.Gyro=bg
        else
            hum.PlatformStand=false
            if S.Fly.Body then S.Fly.Body:Destroy(); S.Fly.Body=nil end
            if S.Fly.Gyro then S.Fly.Gyro:Destroy(); S.Fly.Gyro=nil end
        end
    end
    if inp.KeyCode==Enum.KeyCode.C then
        S.FreeCam.Enabled=not S.FreeCam.Enabled
        if S.FreeCam.Enabled then
            fcCF=Cam.CFrame; local _,yaw,_=Cam.CFrame:ToEulerAnglesYXZ(); fcYaw=math.deg(yaw); fcPitch=0
            Cam.CameraType=Enum.CameraType.Scriptable; UserInputService.MouseBehavior=Enum.MouseBehavior.LockCenter
        else
            Cam.CameraType=Enum.CameraType.Custom; Cam.CameraSubject=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid") or nil
            UserInputService.MouseBehavior=Enum.MouseBehavior.Default
        end
    end
end)

