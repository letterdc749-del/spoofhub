-- DEATH SCREEN
----------------------------------------------------------------
local _deathOverlay    = nil
local _deathScanConn   = nil
local _deathCountConn  = nil

local function showDeathScreen(seconds, locationName, displayName)
    if _deathOverlay then pcall(function() _deathOverlay:Destroy() end); _deathOverlay=nil end
    if _deathScanConn then _deathScanConn:Disconnect(); _deathScanConn=nil end
    if _deathCountConn then _deathCountConn:Disconnect(); _deathCountConn=nil end

    local destName = locationName or "Unknown"
    local playerName = displayName or LP.DisplayName

    task.spawn(function()
        local waited=0
        while not _G.SPOOFHUB_SG and waited<5 do task.wait(0.05); waited=waited+0.05 end
        local sg=_G.SPOOFHUB_SG; if not sg then return end

        local overlay=Instance.new("Frame",sg)
        overlay.Name="DeathScreen"; overlay.Size=UDim2.new(1,0,1,0)
        overlay.BackgroundColor3=Color3.fromRGB(0,0,0)
        overlay.BackgroundTransparency=1; overlay.BorderSizePixel=0; overlay.ZIndex=999
        _deathOverlay=overlay

        -- Scan line
        local scan=Instance.new("Frame",overlay)
        scan.Size=UDim2.new(1,0,0,2); scan.BackgroundColor3=Color3.fromRGB(180,0,0)
        scan.BorderSizePixel=0; scan.ZIndex=1000; scan.BackgroundTransparency=0.4

        -- SPOOFHUB title
        local title=Instance.new("TextLabel",overlay)
        title.Text="SPOOFHUB"; title.Font=Enum.Font.GothamBold; title.TextSize=72
        title.TextColor3=Color3.fromRGB(200,30,40); title.BackgroundTransparency=1
        title.Size=UDim2.new(1,0,0,80); title.Position=UDim2.new(0,0,0.22,0)
        title.TextXAlignment=Enum.TextXAlignment.Center; title.ZIndex=1000
        title.TextStrokeTransparency=0.3; title.TextStrokeColor3=Color3.fromRGB(0,0,0)

        -- Subtitle
        local sub=Instance.new("TextLabel",overlay)
        sub.Text="I S   T E L E P O R T I N G   Y O U"
        sub.Font=Enum.Font.GothamBold; sub.TextSize=16
        sub.TextColor3=Color3.fromRGB(220,220,220); sub.BackgroundTransparency=1
        sub.Size=UDim2.new(1,0,0,22); sub.Position=UDim2.new(0,0,0.22,88)
        sub.TextXAlignment=Enum.TextXAlignment.Center; sub.ZIndex=1000
        sub.TextStrokeTransparency=0.4; sub.TextStrokeColor3=Color3.fromRGB(0,0,0)

        -- Divider
        local div=Instance.new("Frame",overlay)
        div.Size=UDim2.new(0,260,0,1); div.AnchorPoint=Vector2.new(0.5,0)
        div.Position=UDim2.new(0.5,0,0.22,118)
        div.BackgroundColor3=Color3.fromRGB(180,0,0); div.BorderSizePixel=0; div.ZIndex=1000

        -- Display name label only
        local nameLbl=Instance.new("TextLabel",overlay)
        nameLbl.Text=playerName
        nameLbl.Font=Enum.Font.GothamBold; nameLbl.TextSize=20
        nameLbl.TextColor3=Color3.fromRGB(255,255,255); nameLbl.BackgroundTransparency=1
        nameLbl.Size=UDim2.new(1,0,0,26); nameLbl.Position=UDim2.new(0,0,0.22,128)
        nameLbl.TextXAlignment=Enum.TextXAlignment.Center; nameLbl.ZIndex=1000
        nameLbl.TextStrokeTransparency=0.4; nameLbl.TextStrokeColor3=Color3.fromRGB(0,0,0)

        -- Countdown
        local countLbl=Instance.new("TextLabel",overlay)
        countLbl.Text=tostring(math.ceil(seconds))
        countLbl.Font=Enum.Font.GothamBold; countLbl.TextSize=56
        countLbl.TextColor3=Color3.fromRGB(255,255,255); countLbl.BackgroundTransparency=1
        countLbl.Size=UDim2.new(1,0,0,64); countLbl.Position=UDim2.new(0,0,0.22,162)
        countLbl.TextXAlignment=Enum.TextXAlignment.Center; countLbl.ZIndex=1000
        countLbl.TextStrokeTransparency=0.4; countLbl.TextStrokeColor3=Color3.fromRGB(0,0,0)

        -- Progress bar
        local barTrack=Instance.new("Frame",overlay)
        barTrack.Size=UDim2.new(0,300,0,4); barTrack.AnchorPoint=Vector2.new(0.5,0)
        barTrack.Position=UDim2.new(0.5,0,0.22,236)
        barTrack.BackgroundColor3=Color3.fromRGB(35,35,35); barTrack.BorderSizePixel=0; barTrack.ZIndex=1000
        Instance.new("UICorner",barTrack).CornerRadius=UDim.new(1,0)
        local barFill=Instance.new("Frame",barTrack)
        barFill.Size=UDim2.new(1,0,1,0); barFill.BackgroundColor3=Color3.fromRGB(180,0,0)
        barFill.BorderSizePixel=0; barFill.ZIndex=1001
        Instance.new("UICorner",barFill).CornerRadius=UDim.new(1,0)

        -- Fade to full black
        TweenService:Create(overlay,TweenInfo.new(0.2),{BackgroundTransparency=0}):Play()

        -- Scan line animation
        local scanY=0
        _deathScanConn=RunService.RenderStepped:Connect(function(dt)
            if not overlay.Parent then return end
            scanY=(scanY+dt*180)%math.max(overlay.AbsoluteSize.Y,1)
            scan.Position=UDim2.new(0,0,0,scanY)
        end)

        -- Countdown ticker
        local remaining=seconds
        _deathCountConn=RunService.Heartbeat:Connect(function(dt)
            if not overlay.Parent then
                if _deathScanConn then _deathScanConn:Disconnect(); _deathScanConn=nil end
                if _deathCountConn then _deathCountConn:Disconnect(); _deathCountConn=nil end
                return
            end
            remaining=remaining-dt
            if remaining<0 then remaining=0 end
            countLbl.Text=tostring(math.ceil(remaining))
            barFill.Size=UDim2.new(math.max(remaining/seconds,0),0,1,0)
            if remaining<=0 then
                if _deathScanConn then _deathScanConn:Disconnect(); _deathScanConn=nil end
                if _deathCountConn then _deathCountConn:Disconnect(); _deathCountConn=nil end
                TweenService:Create(overlay,TweenInfo.new(0.5),{BackgroundTransparency=1}):Play()
                task.delay(0.55,function() pcall(function() overlay:Destroy() end); _deathOverlay=nil end)
            end
        end)
    end)
end

local function hideDeathScreen()
    if _deathScanConn then _deathScanConn:Disconnect(); _deathScanConn=nil end
    if _deathCountConn then _deathCountConn:Disconnect(); _deathCountConn=nil end
    if _deathOverlay then
        TweenService:Create(_deathOverlay,TweenInfo.new(0.5),{BackgroundTransparency=1}):Play()
        local ov=_deathOverlay; _deathOverlay=nil
        task.delay(0.55,function() pcall(function() ov:Destroy() end) end)
    end
end

