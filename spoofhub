local function startPlay()
    if #Rec.Frames==0 then notify("Recorder","Nothing to play",nil); return end
    stopAll(); Rec.Playing=true; Rec.CurrentRep=0; Rec.PlayIdx=0; Rec.PrevHeld={}
    pBtn.Text="⏹  Stop"; TweenService:Create(pBtn,TweenInfo.new(0.1),{BackgroundColor3=T.accent}):Play()
    notify("Recorder","Playing x"..Rec.RepeatCount,nil)
    Rec.Conn=RunService.RenderStepped:Connect(function()
        if not Rec.Playing then return end
        Rec.PlayIdx=Rec.PlayIdx+1
        if Rec.PlayIdx>#Rec.Frames then
            Rec.CurrentRep=Rec.CurrentRep+1
            if Rec.CurrentRep>Rec.RepeatCount then stopPlay(); notify("Recorder","Done!","success"); return end
            releaseAll(); Rec.PlayIdx=1
        end
        local frame=Rec.Frames[Rec.PlayIdx]; if not frame then return end
        local mx=frame["MX"] or 0; local my=frame["MY"] or 0
        pcall(function() VIM2:SendMouseMoveEvent(mx,my,game) end)
        for _,kc in ipairs(WATCH_KEYS) do
            local was=Rec.PrevHeld[kc] or false; local now=frame[kc] or false
            if now and not was then fireKey(true,kc) elseif not now and was then fireKey(false,kc) end
        end
        local wasMB1=Rec.PrevHeld["MB1"] or false; local nowMB1=frame["MB1"] or false
        if nowMB1 and not wasMB1 then pcall(function() VIM2:SendMouseButtonEvent(mx,my,0,true,game,0) end)
        elseif not nowMB1 and wasMB1 then pcall(function() VIM2:SendMouseButtonEvent(mx,my,0,false,game,0) end) end
        local wasMB2=Rec.PrevHeld["MB2"] or false; local nowMB2=frame["MB2"] or false
        if nowMB2 and not wasMB2 then pcall(function() VIM2:SendMouseButtonEvent(mx,my,1,true,game,0) end)
        elseif not nowMB2 and wasMB2 then pcall(function() VIM2:SendMouseButtonEvent(mx,my,1,false,game,0) end) end
        Rec.PrevHeld=frame; upd()
    end)
end

