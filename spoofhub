local DrawingLib = Drawing or (getgenv and getgenv().Drawing) or nil
local function D(t)
    if not DrawingLib then
        local s = {}
        setmetatable(s, {__index=function() return s end, __newindex=function() end})
        s.Remove = function() end
        return s
    end
    return DrawingLib.new(t)
end

