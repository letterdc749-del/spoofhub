    local n=0
    pcall(function()
        for _,v in ipairs(LP.Backpack:GetChildren()) do if v:IsA("Tool") and v.Name==name then n+=1 end end
        if LP.Character then for _,v in ipairs(LP.Character:GetChildren()) do if v:IsA("Tool") and v.Name==name then n+=1 end end end
    end)
    return n
end

local function getMarshmallows()
    local items={}
    local function scan(c) if not c then return end
        for _,v in ipairs(c:GetChildren()) do
            if v:IsA("Tool") then local n=v.Name:lower(); if n:find("marshmallow") or n:find("marsh") then table.insert(items,v) end end
        end
    end
    scan(LP.Backpack); if LP.Character then scan(LP.Character) end
    return items
end

